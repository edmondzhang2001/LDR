# Google Sign-In (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
# Web client ID: used by the backend to verify the id token. Create a "Web application" client.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID: required on iOS when not using GoogleService-Info.plist. Create an "iOS" client.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
