# Google Sign-In (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
# Web client ID: used by the backend to verify the id token. Create a "Web application" client.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client ID: required on iOS when not using GoogleService-Info.plist. Create an "iOS" client.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# OpenWeatherMap API key (https://openweathermap.org/api) for Partner Stats weather.
EXPO_PUBLIC_WEATHER_API_KEY=your-openweathermap-api-key

# RevenueCat (https://www.revenuecat.com) — test key for dev, project API key for prod
EXPO_PUBLIC_REVENUECAT_API_KEY=your-revenuecat-api-key
# Optional: entitlement identifier (defaults to 'premium' if unset)
# EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium

# Backend API base URL (default: http://localhost:3000). Use a tunnel URL (e.g. localtunnel, ngrok) for device or webhooks.
# EXPO_PUBLIC_API_URL=https://your-tunnel.loca.lt
