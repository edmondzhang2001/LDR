# Server
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ldr

# JWT
JWT_SECRET=your-secret-key-change-in-production

# OAuth (for token verification)
# GOOGLE_CLIENT_ID = Web OAuth client ID (from Google Cloud Console). Same as frontend EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# APPLE_CLIENT_ID = Your iOS app bundle identifier (e.g. com.anonymous.frontend from app.json).
APPLE_CLIENT_ID=your-app-bundle-id

# Rate limiting (optional; defaults shown)
# RATE_LIMIT_MAX=200
# RATE_LIMIT_AUTH_MAX=15
# RATE_LIMIT_PAIRING_MAX=20

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ldr-uploads
